<%- include('layout', { user: user, body: '' }) %>
<% function renderBody(){ %>
  <div class="container py-5">
    <!-- Header -->
    <div class="mb-5">
      <h1 class="mb-2"><i class="fas fa-shield-alt"></i> Admin Dashboard</h1>
      <p class="text-muted">Welcome back, <strong><%= user.name %></strong></p>
    </div>

    <!-- Stats Section -->
    <div class="row mb-5">
      <div class="col-md-4 mb-3">
        <div class="auth-card text-center">
          <h3 style="color: var(--primary-green); font-size: 2.5rem;"><%=users ? users.length : 0%></h3>
          <p class="text-muted"><i class="fas fa-users"></i> Total Users</p>
        </div>
      </div>
      <div class="col-md-4 mb-3">
        <div class="auth-card text-center">
          <h3 style="color: var(--primary-green); font-size: 2.5rem;"><%=products ? products.length : 0%></h3>
          <p class="text-muted"><i class="fas fa-store"></i> Total Products</p>
        </div>
      </div>
      <div class="col-md-4 mb-3">
        <div class="auth-card text-center">
          <h3 style="color: var(--primary-green); font-size: 2.5rem;">12</h3>
          <p class="text-muted"><i class="fas fa-chart-line"></i> Orders Today</p>
        </div>
      </div>
    </div>

    <!-- Users Management Section -->
    <section class="mb-5">
      <h2 class="mb-4 section-title"><i class="fas fa-users-cog"></i> User Management</h2>
      <div class="table-responsive">
        <table class="table table-hover">
          <thead style="background: linear-gradient(135deg, var(--primary-green), var(--secondary-purple)); color: white;">
            <tr>
              <th><i class="fas fa-user"></i> Name</th>
              <th><i class="fas fa-envelope"></i> Email</th>
              <th><i class="fas fa-briefcase"></i> Role</th>
              <th><i class="fas fa-map-marker-alt"></i> District</th>
              <th><i class="fas fa-cogs"></i> Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if(users && users.length > 0) { %>
              <% users.forEach(function(u){ %>
                <tr>
                  <td><strong><%= u.name %></strong></td>
                  <td><%= u.email %></td>
                  <td>
                    <span class="badge" style="background: var(--primary-green);">
                      <%= u.role.charAt(0).toUpperCase() + u.role.slice(1) %>
                    </span>
                  </td>
                  <td><%= u.district || '-' %></td>
                  <td>
                    <button class="btn btn-sm btn-outline-danger" onclick="deleteUser(<%= u.id %>)">
                      <i class="fas fa-trash"></i> Delete
                    </button>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr><td colspan="5" class="text-center text-muted py-4"><i class="fas fa-inbox"></i> No users yet</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Products Management Section -->
    <section>
      <h2 class="mb-4 section-title"><i class="fas fa-store"></i> Products on Platform</h2>
      <% if(products && products.length > 0) { %>
        <div class="product-grid">
          <% products.forEach(function(p){ %>
            <div class="product-card">
              <img src="<%= p.image || '/images/placeholder.png' %>" alt="<%= p.name_en %>">
              <div class="product-card-body">
                <h3><%= p.name_en %></h3>
                <% if(p.description) { %>
                  <p class="text-muted small"><%= p.description %></p>
                <% } %>
                <div class="product-price">Rs. <%= p.price %> <span style="font-size: 0.8rem; color: var(--text-light);">/ unit</span></div>
                <button class="btn btn-sm btn-outline-danger w-100" onclick="deleteProduct(<%= p.id %>)">
                  <i class="fas fa-trash"></i> Remove
                </button>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="alert alert-info text-center">
          <i class="fas fa-info-circle"></i> No products on platform yet
        </div>
      <% } %>
    </section>
  </div>

  <script>
    async function deleteUser(id) {
      if (!confirm('Are you sure you want to delete this user? This action cannot be undone.')) return;
      const res = await fetch('/api/users/' + id, { method: 'DELETE' });
      if (res.ok) {
        alert('✓ User deleted successfully');
        location.reload();
      } else {
        alert('❌ Failed to delete user');
      }
    }

    async function deleteProduct(id) {
      if (!confirm('Are you sure you want to remove this product?')) return;
      const res = await fetch('/api/products/' + id, { method: 'DELETE' });
      if (res.ok) {
        alert('✓ Product removed successfully');
        location.reload();
      } else {
        alert('❌ Failed to remove product');
      }
    }
  </script>
<% } %>
<%- renderBody() %>
