<%- include('layout', { user: user, body: '' }) %>
<% function renderBody(){ %>
  <div class="container py-5">
    <!-- Header -->
    <div class="mb-5">
      <h1 class="mb-2"><i class="bi bi-person-circle"></i> Welcome, <span style="color: var(--primary-green);"><%=user.name%></span></h1>
      <p class="text-muted"><i class="bi bi-geo"></i> <%=user.district || 'Location not set'%> | <i class="bi bi-telephone"></i> <%=user.contact || 'No contact'%></p>
    </div>

    <!-- Your Listings Section -->
    <section class="mb-5">
      <h2 class="mb-4 section-title"><i class="bi bi-bookmark-star"></i> Your Listings</h2>
      <% if(products && products.length > 0) { %>
        <div class="product-grid">
          <% products.forEach(function(p){ %>
            <div class="product-card">
              <img src="<%= p.image || '/images/placeholder.png' %>" alt="<%= p.name_en %>">
              <div class="product-card-body">
                <h3><%= p.name_en %></h3>
                <% if(p.description) { %>
                  <p class="text-muted small"><%= p.description %></p>
                <% } %>
                <div class="product-price">Rs. <%= p.price %> <span style="font-size: 0.8rem; color: var(--text-light);">/ unit</span></div>
                <div class="d-grid gap-2">
                  <button class="btn btn-outline-primary btn-sm" onclick="editProduct(<%= p.id %>)">
                    <i class="bi bi-pencil"></i> Edit
                  </button>
                  <button class="btn btn-outline-danger btn-sm" onclick="deleteProduct(<%= p.id %>)">
                    <i class="bi bi-trash"></i> Delete
                  </button>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="alert alert-info text-center">
          <i class="bi bi-exclamation-circle"></i> You haven't added any products yet
        </div>
      <% } %>
    </section>

    <!-- Add Product Section -->
    <section class="mt-5">
      <div class="auth-card">
        <h2 class="mb-4"><i class="bi bi-plus-circle"></i> Add New Product</h2>
        <form id="productForm" enctype="multipart/form-data">
          <div class="row">
            <div class="col-md-6 mb-3">
              <label class="form-label"><i class="bi bi-type"></i> Product Name (English)</label>
              <input class="form-control" name="name_en" placeholder="e.g., Fresh Tomatoes" required>
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label"><i class="bi bi-type"></i> नाम (Nepali)</label>
              <input class="form-control" name="name_np" placeholder="e.g., ताजा टमाटर">
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label"><i class="bi bi-textarea-t"></i> Description</label>
            <textarea class="form-control" name="description" placeholder="Describe your product..." rows="3"></textarea>
          </div>

          <div class="row">
            <div class="col-md-4 mb-3">
              <label class="form-label"><i class="bi bi-currency-exchange"></i> Price (NPR)</label>
              <input class="form-control" name="price" type="number" placeholder="0.00" required>
            </div>
            <div class="col-md-4 mb-3">
              <label class="form-label"><i class="bi bi-tag"></i> Category</label>
              <select class="form-control" name="category_id">
                <option value="">Select Category</option>
                <option value="1">Vegetables</option>
                <option value="2">Fruits</option>
                <option value="3">Grains</option>
                <option value="4">Dairy</option>
              </select>
            </div>
            <div class="col-md-4 mb-3">
              <label class="form-label"><i class="bi bi-image"></i> Product Image</label>
              <input class="form-control" type="file" name="image" accept="image/*">
            </div>
          </div>

          <button class="btn btn-success w-100" type="submit">
            <i class="bi bi-check-circle"></i> Add Product
          </button>
        </form>
        <div id="productMessage" class="auth-message mt-3"></div>
      </div>
    </section>
  </div>

  <script>
    document.getElementById('productForm').addEventListener('submit', async function(e){
      e.preventDefault();
      const fd = new FormData(this);
      const res = await fetch('/api/products', { method:'POST', body: fd });
      const data = await res.json();
      const msg = document.getElementById('productMessage');
      if (res.ok) { 
        msg.className = 'auth-message success';
        msg.innerText = '✓ Product added successfully!';
        setTimeout(() => location.reload(), 1500);
      } else { 
        msg.className = 'auth-message error';
        msg.innerText = '❌ ' + (data.error || 'Failed to add product'); 
      }
    });

    function editProduct(id) {
      alert('Edit product ' + id + ' (Feature coming soon)');
    }

    function deleteProduct(id) {
      if (confirm('Are you sure you want to delete this product?')) {
        alert('Deleting product ' + id + '...');
      }
    }
  </script>
<% } %>
<%- renderBody() %>
