<%- include('layout', { user: user, body: '' }) %>
<% function renderBody(){ %>
  <section id="home" class="hero-section text-center" style="background: url('/images/market4.jpg') center/cover no-repeat; height: 60vh; position: relative; display: flex; align-items: center; justify-content: center;">
    <div class="overlay"></div>
    <div class="hero-content">
      <h1>Connecting Farmers with Buyers</h1>
      <p>Fresh, Fair, and Sustainable Trade in Nepal</p>
      <a href="#products" class="btn btn-success btn-lg mt-3">Explore Products</a>
    </div>
  </section>

  <section id="products">
    <h2><i class="bi bi-cart-fill"></i> Available Products</h2>
    <div class="product-grid">
      <% products.forEach(function(p){ %>
        <div class="product-card">
          <img src="<%= p.image || '/images/placeholder.png' %>" alt="<%= p.name_en %>">
          <h3><%= p.name_en %></h3>
          <p>Rs. <%= p.price %> / kg</p>
          <a class="btn btn-success" href="/">View</a>
        </div>
      <% }) %>
    </div>
  </section>
<% } %>
<%- renderBody() %>
