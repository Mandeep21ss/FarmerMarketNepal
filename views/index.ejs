<%- include('layout', { user: user, body: '' }) %>
<% function renderBody(){ %>
  <section id="home" class="hero-section text-center" style="background: url('/images/market4.jpg') center/cover no-repeat; position: relative;">
    <div class="overlay"></div>
    <div class="hero-content">
      <h1>🌾 Connecting Farmers with Buyers</h1>
      <p>Fresh, Fair, and Sustainable Trade in Nepal</p>
      <a href="#products" class="btn btn-success btn-lg mt-3">↓ Explore Products ↓</a>
    </div>
  </section>

  <section id="products">
    <h2><i class="fas fa-shopping-cart"></i> Fresh Products Available</h2>
    <div class="product-grid">
      <% 
        const sampleProducts = [
          { name: 'Tomatoes', price: 80, img: 'https://images.unsplash.com/photo-1595521594422-46a068b84d59?w=400&h=300&fit=crop' },
          { name: 'Fresh Lettuce', price: 60, img: 'https://images.unsplash.com/photo-1578985545062-69928b1d9587?w=400&h=300&fit=crop' },
          { name: 'Carrots', price: 50, img: 'https://images.unsplash.com/photo-1598103442097-8b74394b95c6?w=400&h=300&fit=crop' },
          { name: 'Apples', price: 120, img: 'https://images.unsplash.com/photo-1560806e614371-a58e7ef0f28f?w=400&h=300&fit=crop' },
          { name: 'Bananas', price: 70, img: 'https://images.unsplash.com/photo-1571019614242-c5c5dee9f50b?w=400&h=300&fit=crop' },
          { name: 'Potatoes', price: 40, img: 'https://images.unsplash.com/photo-1596042222126-3aa2e43fc25f?w=400&h=300&fit=crop' },
          { name: 'Onions', price: 45, img: 'https://images.unsplash.com/photo-1587049677318-fa89f7cf708f?w=400&h=300&fit=crop' },
          { name: 'Spinach', price: 55, img: 'https://images.unsplash.com/photo-1599019062536-2b5eef64998e?w=400&h=300&fit=crop' }
        ];
        const displayProducts = products && products.length > 0 ? products : sampleProducts;
      %>
      <% displayProducts.forEach(function(p){ %>
        <div class="product-card">
          <img src="<%= p.img || p.image || '/images/placeholder.png' %>" alt="<%= p.name || p.name_en %>">
          <div class="product-card-body">
            <h3><%= p.name || p.name_en %></h3>
            <p class="text-muted small"><%= p.description || 'High quality fresh produce' %></p>
            <div class="product-price">Rs. <%= p.price %> <span style="font-size: 0.8rem; color: var(--text-light);">/ kg</span></div>
            <a class="btn btn-success w-100" href="/">
              <i class="fas fa-shopping-bag"></i> Add to Cart
            </a>
          </div>
        </div>
      <% }) %>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="contact-info-section">
    <div class="container">
      <h2 class="section-title text-white text-center"><i class="fas fa-phone"></i> Get in Touch</h2>
      <div class="row">
        <div class="col-md-6">
          <ul class="contact-details">
            <li>
              <i class="fas fa-map-marker-alt"></i>
              <span><strong>Address:</strong> Kathmandu, Nepal</span>
            </li>
            <li>
              <i class="fas fa-phone"></i>
              <span><strong>Phone:</strong> +977-1-234-5678</span>
            </li>
            <li>
              <i class="fas fa-envelope"></i>
              <span><strong>Email:</strong> info@farmersmarket.np</span>
            </li>
            <li>
              <i class="fas fa-clock"></i>
              <span><strong>Hours:</strong> 8 AM - 6 PM Daily</span>
            </li>
          </ul>
        </div>
        <div class="col-md-6">
          <div class="text-white text-center">
            <h5 class="mb-3">Follow Us</h5>
            <div class="social-icons">
              <a href="#" title="Facebook"><i class="fab fa-facebook"></i></a>
              <a href="#" title="Instagram"><i class="fab fa-instagram"></i></a>
              <a href="#" title="Twitter"><i class="fab fa-twitter"></i></a>
              <a href="#" title="LinkedIn"><i class="fab fa-linkedin"></i></a>
              <a href="#" title="YouTube"><i class="fab fa-youtube"></i></a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
<% } %>
<%- renderBody() %>
