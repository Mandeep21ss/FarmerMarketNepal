<%- include('layout', { user: user, body: '' }) %>
<% function renderBody(){ %>
  <section id="home" class="hero-section text-center" style="background: linear-gradient(135deg, rgba(16, 185, 129, 0.6) 0%, rgba(139, 92, 246, 0.6) 100%), url('/images/tomato.png') center/cover no-repeat; position: relative;">
    <div class="overlay"></div>
    <div class="hero-content">
      <h1>🌾 Connecting Farmers with Buyers</h1>
      <p>Fresh, Fair, and Sustainable Trade in Nepal</p>
      <a href="#products" class="btn btn-success btn-lg mt-3">↓ Explore Fresh Products ↓</a>
    </div>
  </section>

  <section id="products">
    <h2><i class="bi bi-cart-fill"></i> Fresh Products from Local Farmers</h2>
    <div class="product-grid">
      <!-- Featured Tomato Product -->
      <div class="product-card featured-card">
        <img src="/images/tomato.png" alt="Fresh Tomatoes">
        <div class="product-card-body">
          <h3>🍅 Fresh Tomatoes</h3>
          <p class="text-muted small">Premium quality, locally grown organic tomatoes</p>
          <div class="product-price">Rs. 80 <span style="font-size: 0.8rem; color: var(--text-light);">/ kg</span></div>
          <a class="btn btn-success w-100" href="/">
            <i class="bi bi-bag-plus"></i> Add to Cart
          </a>
        </div>
      </div>

      <!-- Additional Products with Tomato Image -->
      <% if(products && products.length > 0) { %>
        <% products.forEach(function(p){ %>
          <div class="product-card">
            <img src="<%= p.image || '/images/tomato.png' %>" alt="<%= p.name_en %>">
            <div class="product-card-body">
              <h3><%= p.name_en %></h3>
              <p class="text-muted small"><%= p.description || 'High quality fresh produce' %></p>
              <div class="product-price">Rs. <%= p.price %> <span style="font-size: 0.8rem; color: var(--text-light);">/ kg</span></div>
              <a class="btn btn-success w-100" href="/">
                <i class="bi bi-bag-plus"></i> Add to Cart
              </a>
            </div>
          </div>
        <% }) %>
      <% } %>

      <!-- Sample Products -->
      <div class="product-card">
        <img src="/images/tomato.png" alt="Fresh Vegetables">
        <div class="product-card-body">
          <h3>🥒 Fresh Cucumbers</h3>
          <p class="text-muted small">Crisp, refreshing cucumbers from mountain farms</p>
          <div class="product-price">Rs. 60 <span style="font-size: 0.8rem; color: var(--text-light);">/ kg</span></div>
          <a class="btn btn-success w-100" href="/">
            <i class="bi bi-bag-plus"></i> Add to Cart
          </a>
        </div>
      </div>

      <div class="product-card">
        <img src="/images/tomato.png" alt="Fresh Vegetables">
        <div class="product-card-body">
          <h3>🌶️ Green Peppers</h3>
          <p class="text-muted small">Sweet and spicy peppers, pesticide-free</p>
          <div class="product-price">Rs. 120 <span style="font-size: 0.8rem; color: var(--text-light);">/ kg</span></div>
          <a class="btn btn-success w-100" href="/">
            <i class="bi bi-bag-plus"></i> Add to Cart
          </a>
        </div>
      </div>

      <div class="product-card">
        <img src="/images/tomato.png" alt="Fresh Vegetables">
        <div class="product-card-body">
          <h3>🥦 Fresh Broccoli</h3>
          <p class="text-muted small">Nutritious, vibrant broccoli florets</p>
          <div class="product-price">Rs. 90 <span style="font-size: 0.8rem; color: var(--text-light);">/ kg</span></div>
          <a class="btn btn-success w-100" href="/">
            <i class="bi bi-bag-plus"></i> Add to Cart
          </a>
        </div>
      </div>

      <div class="product-card">
        <img src="/images/tomato.png" alt="Fresh Vegetables">
        <div class="product-card-body">
          <h3>🧅 Onions</h3>
          <p class="text-muted small">Golden, flavorful onions with long shelf life</p>
          <div class="product-price">Rs. 50 <span style="font-size: 0.8rem; color: var(--text-light);">/ kg</span></div>
          <a class="btn btn-success w-100" href="/">
            <i class="bi bi-bag-plus"></i> Add to Cart
          </a>
        </div>
      </div>

      <div class="product-card">
        <img src="/images/tomato.png" alt="Fresh Vegetables">
        <div class="product-card-body">
          <h3>🥬 Spinach</h3>
          <p class="text-muted small">Fresh, organic spinach leaves for salads</p>
          <div class="product-price">Rs. 100 <span style="font-size: 0.8rem; color: var(--text-light);">/ kg</span></div>
          <a class="btn btn-success w-100" href="/">
            <i class="bi bi-bag-plus"></i> Add to Cart
          </a>
        </div>
      </div>
    </div>
  </section>
<% } %>
<%- renderBody() %>

