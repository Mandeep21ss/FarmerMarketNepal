<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Farmers Marketplace Nepal</title>
    <link rel="stylesheet" href="/css/style.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Heroicons from Tailwind -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&family=Roboto:wght@300;400;500;700&family=Open+Sans:wght@300;400;600;700&display=swap" rel="stylesheet">
  </head>
  <body>
    <!-- Navigation Bar -->
    <nav class="navbar navbar-expand-lg navbar-light">
      <div class="container">
        <a class="navbar-brand" href="/">
          <img src="/images/logo1.png" alt="Farmers Marketplace" style="height: 84px; margin-right: 12px; border-radius: 8px; object-fit: cover;">
          <strong>Farmers Marketplace</strong>
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navMenu">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item"><a class="nav-link" href="/"><i class="fas fa-home"></i> Home</a></li>
            <li class="nav-item"><a class="nav-link" href="/#products"><i class="fas fa-store"></i> Products</a></li>
            <% if (!user) { %>
              <li class="nav-item"><a class="nav-link" href="/login"><i class="fas fa-sign-in-alt"></i> Login</a></li>
              <li class="nav-item"><a class="nav-link" href="/register"><i class="fas fa-user-plus"></i> Register</a></li>
            <% } else { %>
              <li class="nav-item"><a class="nav-link" href="/dashboard"><i class="fas fa-chart-line"></i> Dashboard</a></li>
              <li class="nav-item"><a class="nav-link" href="/dashboard/settings"><i class="fas fa-cog"></i> Settings</a></li>
              <li class="nav-item">
                <form method="post" action="/api/auth/logout" style="display: inline;">
                  <button type="submit" class="nav-link btn btn-link"><i class="fas fa-sign-out-alt"></i> Logout</button>
                </form>
              </li>
            <% } %>
          </ul>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main>
      <%- body %>
    </main>

    <!-- Sticky Cart Button (Buyers Only) -->
    <% if (user && user.role === 'buyer') { %>
      <button class="btn btn-success cart-btn" onclick="openCartModal()" title="View Cart">
        <i class="fas fa-shopping-cart"></i>
        <span id="cartBadge" class="ms-2 badge bg-danger">0</span>
      </button>

      <!-- Cart Modal -->
      <div id="cartModal" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-lg">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title"><i class="fas fa-shopping-cart"></i> Your Cart</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
              <div id="cartState">
                <p class="text-muted">Loading cart...</p>
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
              <button type="button" class="btn btn-success" onclick="checkoutCart()"><i class="fas fa-credit-card"></i> Checkout</button>
            </div>
          </div>
        </div>
      </div>
    <% } %>
    <!-- Footer -->
    <footer>
      <div class="container">
        <div class="row mb-4">
          <div class="col-md-4 text-center">
            <h6><i class="fas fa-truck"></i> Fast Delivery</h6>
            <p class="small">Fresh products delivered to your doorstep</p>
          </div>
          <div class="col-md-4 text-center">
            <h6><i class="fas fa-shield-alt"></i> Secure & Safe</h6>
            <p class="small">Trusted platform for fair trade</p>
          </div>
          <div class="col-md-4 text-center">
            <h6><i class="fas fa-award"></i> Quality Assured</h6>
            <p class="small">100% fresh & organic products</p>
          </div>
        </div>
        <hr class="border-secondary">
        <p class="text-center mb-0">
          &copy; 2024 Farmers Marketplace Nepal. All rights reserved. | 
          <a href="#" class="text-decoration-none">Privacy Policy</a> | 
          <a href="#" class="text-decoration-none">Terms of Service</a>
        </p>
      </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/script.js"></script>
    <% if (user && user.role === 'buyer') { %>
    <script>
      const cartModal = new bootstrap.Modal(document.getElementById('cartModal'), { backdrop: 'static' });

      function openCartModal() {
        fetchCart();
        cartModal.show();
      }

      async function fetchCart() {
        const res = await fetch('/api/cart');
        if (!res.ok) return document.getElementById('cartState').innerHTML = '<div class="alert alert-danger">Unable to load cart.</div>';
        const cart = await res.json();
        document.getElementById('cartBadge').innerText = cart.totalItems || 0;
        renderCart(cart);
      }

      function renderCart(cart) {
        if (!cart.items.length) {
          document.getElementById('cartState').innerHTML = '<p class="text-muted text-center">Your cart is empty.</p>';
          return;
        }

        const rows = cart.items.map(item => `
          <div class="cart-item mb-3 p-3 bg-light rounded">
            <div class="row align-items-center">
              <div class="col-md-2">
                <img src="${item.image || '/images/placeholder.png'}" class="img-fluid rounded" alt="${item.name}">
              </div>
              <div class="col-md-5">
                <h6>${item.name}</h6>
                <p class="mb-0 text-muted">Rs. ${item.price} / ${item.unit || 'kg'}</p>
              </div>
              <div class="col-md-2">
                <input type="number" min="0" value="${item.quantity}" class="form-control form-control-sm" onchange="updateCartItem(${item.product_id}, this.value)">
              </div>
              <div class="col-md-2 text-end">
                <button class="btn btn-outline-danger btn-sm" onclick="removeCartItem(${item.product_id})"><i class="fas fa-trash"></i></button>
              </div>
            </div>
          </div>
        `).join('');

        document.getElementById('cartState').innerHTML = `
          ${rows}
          <div class="mt-3 p-3 bg-light rounded">
            <strong>Total: Rs. ${cart.totalPrice}</strong>
          </div>
        `;
      }

      async function addToCart(productId) {
        const res = await fetch('/api/cart', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ product_id: productId, quantity: 1 })
        });
        if (res.ok) {
          fetchCart();
          const btn = event.target;
          btn.innerHTML = '<i class="fas fa-check"></i> Added!';
          setTimeout(() => { btn.innerHTML = '<i class="fas fa-shopping-bag"></i> Add to Cart'; }, 1500);
        }
      }

      async function updateCartItem(productId, quantity) {
        const qty = Number(quantity);
        if (qty < 0) return;
        const res = await fetch('/api/cart/' + productId, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ quantity: qty })
        });
        if (res.ok) fetchCart();
      }

      async function removeCartItem(productId) {
        const res = await fetch('/api/cart/' + productId, { method: 'DELETE' });
        if (res.ok) fetchCart();
      }

      async function checkoutCart() {
        const res = await fetch('/api/cart');
        if (!res.ok) return;
        const cart = await res.json();
        if (!cart.items.length) return alert('Your cart is empty.');
        
        const orderRes = await fetch('/api/orders', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: cart.items.map(item => ({ product_id: item.product_id, quantity: item.quantity })) })
        });
        if (orderRes.ok) {
          alert('✓ Order placed successfully!');
          cartModal.hide();
          fetchCart();
        } else {
          const data = await orderRes.json();
          alert('❌ ' + (data.error || 'Checkout failed'));
        }
      }

      fetchCart();
    </script>
    <% } %>
  </body>
</html>
