<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Farmers Marketplace Nepal</title>
    <link rel="stylesheet" href="/css/style.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
  </head>
  <body>
    <!-- Navigation Bar -->
    <nav class="navbar navbar-expand-lg navbar-light fixed-top">
      <div class="container">
        <a class="navbar-brand" href="/">
          <i class="bi bi-leaf"></i>
          Farmers Marketplace
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navMenu">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item"><a class="nav-link" href="/"><i class="bi bi-house"></i> Home</a></li>
            <li class="nav-item"><a class="nav-link" href="/#products"><i class="bi bi-shop"></i> Products</a></li>
            <% if (!user) { %>
              <li class="nav-item"><a class="nav-link" href="/login"><i class="bi bi-box-arrow-in-right"></i> Login</a></li>
              <li class="nav-item"><a class="nav-link" href="/register"><i class="bi bi-person-plus"></i> Register</a></li>
            <% } else { %>
              <li class="nav-item"><a class="nav-link" href="/dashboard"><i class="bi bi-speedometer2"></i> Dashboard</a></li>
              <li class="nav-item">
                <form method="post" action="/api/auth/logout" style="display: inline;">
                  <button class="nav-link btn btn-link"><i class="bi bi-box-arrow-right"></i> Logout</button>
                </form>
              </li>
            <% } %>
          </ul>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main>
      <%- body %>
    </main>

    <!-- Contact Section -->
    <section class="contact-info-section">
      <div class="container">
        <h2 class="section-title text-white text-center"><i class="bi bi-telephone"></i> Get in Touch</h2>
        <div class="row">
          <div class="col-md-6">
            <ul class="contact-details">
              <li>
                <i class="bi bi-geo-alt"></i>
                <span><strong>Address:</strong> Kathmandu, Nepal</span>
              </li>
              <li>
                <i class="bi bi-telephone"></i>
                <span><strong>Phone:</strong> +977-1-234-5678</span>
              </li>
              <li>
                <i class="bi bi-envelope"></i>
                <span><strong>Email:</strong> info@farmersmarket.np</span>
              </li>
              <li>
                <i class="bi bi-clock"></i>
                <span><strong>Hours:</strong> 8 AM - 6 PM Daily</span>
              </li>
            </ul>
          </div>
          <div class="col-md-6">
            <div class="text-white text-center">
              <h5 class="mb-3">Follow Us</h5>
              <div class="social-icons">
                <a href="#" title="Facebook"><i class="bi bi-facebook"></i></a>
                <a href="#" title="Instagram"><i class="bi bi-instagram"></i></a>
                <a href="#" title="Twitter"><i class="bi bi-twitter"></i></a>
                <a href="#" title="LinkedIn"><i class="bi bi-linkedin"></i></a>
                <a href="#" title="YouTube"><i class="bi bi-youtube"></i></a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer>
      <div class="container">
        <div class="row mb-4">
          <div class="col-md-4 text-center">
            <h6><i class="bi bi-truck"></i> Fast Delivery</h6>
            <p class="small">Fresh products delivered to your doorstep</p>
          </div>
          <div class="col-md-4 text-center">
            <h6><i class="bi bi-shield-check"></i> Secure & Safe</h6>
            <p class="small">Trusted platform for fair trade</p>
          </div>
          <div class="col-md-4 text-center">
            <h6><i class="bi bi-award"></i> Quality Assured</h6>
            <p class="small">100% fresh & organic products</p>
          </div>
        </div>
        <hr class="border-secondary">
        <p class="text-center mb-0">
          &copy; 2024 Farmers Marketplace Nepal. All rights reserved. | 
          <a href="#" class="text-decoration-none">Privacy Policy</a> | 
          <a href="#" class="text-decoration-none">Terms of Service</a>
        </p>
      </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/script.js"></script>
  </body>
</html>
