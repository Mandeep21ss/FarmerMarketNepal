<%- include('layout', { user: user, body: '' }) %>
<% function renderBody(){ %>
  <div class="container py-5">
    <!-- Header -->
    <div class="mb-5">
      <h1 class="mb-2"><i class="fas fa-user-circle"></i> Welcome, <span style="color: var(--primary-green);"><%=user.name%></span></h1>
      <p class="text-muted"><i class="fas fa-map-marker-alt"></i> <% if(user.district) { %><%=user.district%><% } else { %>Location not set<% } %></p>
    </div>

    <!-- Available Products Section -->
    <section>
      <h2 class="mb-4 section-title"><i class="fas fa-store"></i> Available Products</h2>
      <div class="product-grid">
        <% products.forEach(function(p){ %>
          <div class="product-card">
            <img src="<%= p.image || '/images/placeholder.png' %>" alt="<%= p.name_en %>">
            <div class="product-card-body">
              <h3><%= p.name_en %></h3>
              <% if(p.description) { %>
                <p class="text-muted small"><%= p.description %></p>
              <% } %>
              <div class="product-price">Rs. <%= p.price %> <span style="font-size: 0.8rem; color: var(--text-light);">/ unit</span></div>
              <button class="btn btn-success w-100" onclick="addToCart('<%= p.name_en %>', <%= p.price %>)">
                <i class="fas fa-shopping-bag"></i> Add to Cart
              </button>
            </div>
          </div>
        <% }) %>
      </div>
      <% if(products.length === 0) { %>
        <div class="alert alert-info text-center mt-5">
          <i class="fas fa-info-circle"></i> No products available at the moment
        </div>
      <% } %>
    </section>
  </div>

  <script>
    function addToCart(name, price) {
      alert('✓ ' + name + ' added to cart! (Demo)');
    }
  </script>
<% } %>
<%- renderBody() %>
